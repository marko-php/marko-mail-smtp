{
    "name": "marko/mail-smtp",
    "description": "SMTP driver for Marko Framework Mail",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.5",
        "marko/core": "self.version",
        "marko/mail": "self.version"
    },
    "require-dev": {
        "marko/testing": "self.version",
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Mail\\Smtp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Mail\\Smtp\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
